# Flask
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Database
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=saa_cms

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Rate limiting storage (memory:// for dev, redis:// URL for production)
RATELIMIT_STORAGE_URI=memory://

# Uploads / resume storage
# STORAGE_BACKEND=local writes to UPLOAD_FOLDER; s3 is a not-yet-implemented
# seam for a future AWS S3 migration (see app/services/storage_service.py).
STORAGE_BACKEND=local
UPLOAD_FOLDER=./uploads
UPLOAD_MAX_MB=5
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email notifications (contact + career form submissions)
# EMAIL_PROVIDER=resend (recommended) or smtp (local dev only - see
# app/services/email_service.py for why Gmail SMTP is not recommended in
# production). EMAIL_TO can be changed any time without touching code.
EMAIL_ENABLED=true
EMAIL_PROVIDER=resend
EMAIL_TO=ujjawaldhiman4@gmail.com
EMAIL_FROM=onboarding@resend.dev
RESEND_API_KEY=

# SMTP fallback - only used when EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# reCAPTCHA
RECAPTCHA_SECRET=
