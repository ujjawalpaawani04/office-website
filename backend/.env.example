# Flask
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Database
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=saa_cms

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Rate limiting storage (memory:// for dev, redis:// URL for production)
RATELIMIT_STORAGE_URI=memory://

# Uploads
UPLOAD_FOLDER=./uploads
UPLOAD_MAX_MB=5

# SMTP (enquiry/career notification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# reCAPTCHA
RECAPTCHA_SECRET=
